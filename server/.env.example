DATABASE_URL="postgresql://ocass:ocass_dev_pw@127.0.0.1:5432/ocassweb"
PORT=5000
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000"

# OTP delivery. In dev mode OTP codes are logged to the server console and
# returned in the API response so the app is testable without an SMS account.
OTP_DEV_MODE=true
OTP_TTL_MINUTES=5

# PayDunya (www.paydunya.com) - Senegalese payment gateway used for checkout.
# Get these from your PayDunya dashboard > API keys. Use "test" mode until
# you've validated the integration against PayDunya's sandbox.
PAYDUNYA_MODE="test"
PAYDUNYA_MASTER_KEY=""
PAYDUNYA_PRIVATE_KEY=""
PAYDUNYA_PUBLIC_KEY=""
PAYDUNYA_TOKEN=""

# Used to build PayDunya's return/cancel/callback URLs. APP_BASE_URL must be
# publicly reachable so PayDunya's servers can reach the IPN callback_url -
# in local dev this only works if you tunnel it (e.g. ngrok).
APP_FRONTEND_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:5000"
